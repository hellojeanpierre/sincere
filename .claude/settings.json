{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "MultiEdit",
      "Grep",
      "Glob",
      "LS",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npm test *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(pip install *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(cat)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(find)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(echo *)",
      "Bash(cd *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(tree)",
      "Bash(tree *)",
      "WebFetch",
      "TodoWrite"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout main)",
      "Bash(git rebase *)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(.env*)",
      "Write(.env*)",
      "Read(./context/**)",
      "Read(./events/**)",
      "Read(./data/**)",
      "Read(./**/*.jsonl)",
      "Read(./**/*.parquet)",
      "Read(./**/*.csv)",
      "Read(./**/*.ndjson)",
      "Read(./**/*.log)",
      "Read(./**/*.gz)",
      "Read(./**/*.zip)"
    ]
  }
}
